{
  "name": "jamessvolos-site",
  "private": true,
  "scripts": {
    "generate": "node generate.js",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./_site/assets/css/app.css --minify",
    "build": "npm run generate && eleventy && npm run build:css",
    "dev": "npm run generate && eleventy --serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "tailwindcss": "^3.4.0"
  }
}
