{
  "name": "jamessvolos.com",
  "version": "1.0.0",
  "private": true,
  "description": "Personal site for James Svolos — static HTML on GitHub Pages, styled with a compiled Tailwind build.",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i assets/css/tailwind.input.css -o assets/css/site.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i assets/css/tailwind.input.css -o assets/css/site.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17"
  }
}
